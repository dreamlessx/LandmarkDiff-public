# LandmarkDiff Environment Variables
# Copy to .env and adjust values for your setup.
# None of these are required for basic inference; defaults work out of the box.

# ── Inference ──────────────────────────────────────────────────

# Inference mode: tps (CPU, geometric only), img2img, controlnet, controlnet_ip
# Default: controlnet (falls back to tps when no GPU is available)
LANDMARKDIFF_MODE=controlnet

# Compute device: cpu, cuda, mps (Apple Silicon)
# Default: auto-detected (cuda if available, else mps, else cpu)
LANDMARKDIFF_DEVICE=cuda

# Root directory for model weights and cached assets
# Default: ~/.cache/landmarkdiff
LANDMARKDIFF_CACHE_DIR=

# Project root override (used by status_report.py and ablation scripts)
# Default: the repo root detected at import time
LANDMARKDIFF_ROOT=

# Conda environment name for SLURM job scripts
# Default: landmarkdiff
LANDMARKDIFF_ENV=landmarkdiff

# ── Model caches ──────────────────────────────────────────────

# HuggingFace hub cache (diffusers, transformers, datasets downloads)
# Default: ~/.cache/huggingface
HF_HOME=

# Set to "1" to block all HuggingFace Hub network calls (offline mode).
# Models must already be cached locally.
HF_HUB_OFFLINE=0

# PyTorch hub cache (torchvision models, etc.)
# Default: ~/.cache/torch
TORCH_HOME=

# ── Training ──────────────────────────────────────────────────

# GPU device selection for training and multi-GPU DDP
# Examples: "0" for single GPU, "0,1,2,3" for 4-GPU DDP
CUDA_VISIBLE_DEVICES=0

# PyTorch CUDA memory allocator tuning (recommended for A6000/A100)
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# NCCL async error handling for multi-GPU stability
TORCH_NCCL_ASYNC_ERROR_HANDLING=1

# ── Weights & Biases ─────────────────────────────────────────

# W&B API key for experiment logging (get from wandb.ai/authorize)
WANDB_API_KEY=

# W&B logging mode: online, offline, disabled
# Use "offline" on HPC nodes without internet access
WANDB_MODE=offline

# Directory for offline W&B run files
WANDB_DIR=

# ── SLURM / HPC ──────────────────────────────────────────────

# SLURM account / allocation for job submission
# Default: default_gpu
SLURM_ACCOUNT=
